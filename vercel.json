{
  "framework": "vite",
  "sourceFilesOutsideRootDirectory": true,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "public": true,
  "installCommand": "npm install",
  "env": {
    "VITE_SUPABASE_URL": "@supabase_url",
    "VITE_SUPABASE_ANON_KEY": "@supabase_anon_key",
    "VITE_API_URL": "@api_url"
  }
}
